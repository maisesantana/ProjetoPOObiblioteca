<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  
  <!-- Login Controller -->
  <servlet>
    <servlet-name>LoginController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.LoginController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginController</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  
  <!-- Administrator Controller -->
  <servlet>
    <servlet-name>AdministratorController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.AdministratorController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdministratorController</servlet-name>
    <url-pattern>/registerEmployee</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdministratorController</servlet-name>
    <url-pattern>/listEmployees</url-pattern>
  </servlet-mapping>

  <!-- Manage Employee Controller -->
  <servlet>
    <servlet-name>ManageEmployeeController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.ManageEmployeeController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ManageEmployeeController</servlet-name>
    <url-pattern>/manageEmployee</url-pattern>
  </servlet-mapping>
  
  <!-- Librarian Controller -->
  <servlet>
    <servlet-name>LibrarianController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.LibrarianController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LibrarianController</servlet-name>
    <url-pattern>/librarian/action</url-pattern>
  </servlet-mapping>
  
  <!-- Attendant Controller -->
  <servlet>
    <servlet-name>AttendantController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.AttendantController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AttendantController</servlet-name>
    <url-pattern>/attendant/action</url-pattern>
  </servlet-mapping>
  
  <!-- Logout Controller -->
  <servlet>
    <servlet-name>LogoutController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.LogoutController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutController</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>
  
</web-app>
