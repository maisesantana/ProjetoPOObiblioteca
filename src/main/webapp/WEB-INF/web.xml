<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  
  <servlet>
    <servlet-name>LoginController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.LoginController</servlet-class>
  </servlet>
  
  <servlet>
    <servlet-name>AdministratorController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.AdministratorController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ManageEmployeeController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.ManageEmployeeController</servlet-class>
  </servlet>
  
  <servlet>
    <servlet-name>LibrarianController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.LibrarianController</servlet-class>
  </servlet>
  
  <servlet>
    <servlet-name>AttendantController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.AttendantController</servlet-class>
  </servlet>
  
  <servlet>
    <servlet-name>LogoutController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.LogoutController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>SearchBooksController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.SearchBooksController</servlet-class>
  </servlet>
  
  <servlet>
    <servlet-name>ViewBookController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.ViewBookController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>RemoveBookController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.RemoveBookController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ManageAuthorsController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.ManageAuthorsController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AddCopiesController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.AddCopiesController</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ManageCategoryController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.ManageCategoryController</servlet-class>
  </servlet>

   <servlet>
  <servlet-name>BookListController</servlet-name>
  <servlet-class>br.com.atlas.webcontroller.BookListController</servlet-class>
</servlet>


  <servlet-mapping>
    <servlet-name>LoginController</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>AdministratorController</servlet-name>
    <url-pattern>/registerEmployee</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdministratorController</servlet-name>
    <url-pattern>/listEmployees</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ManageEmployeeController</servlet-name>
    <url-pattern>/manageEmployee</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>LibrarianController</servlet-name>
    <url-pattern>/librarian/action</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>AttendantController</servlet-name>
    <url-pattern>/attendant/action</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>LogoutController</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>SearchBooksController</servlet-name>
    <url-pattern>/searchBooks</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>ViewBookController</servlet-name>
    <url-pattern>/viewBook</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>RemoveBookController</servlet-name>
    <url-pattern>/removeBook</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ManageAuthorsController</servlet-name>
    <url-pattern>/manageAuthors</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AddCopiesController</servlet-name>
    <url-pattern>/addCopies</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ManageCategoryController</servlet-name>
    <url-pattern>/manageCategory</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ClientController</servlet-name>
    <servlet-class>br.com.atlas.webcontroller.ClientController</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ClientController</servlet-name>
    <url-pattern>/clients</url-pattern>
  </servlet-mapping>

<servlet-mapping>
  <servlet-name>BookListController</servlet-name>
  <url-pattern>/bookList</url-pattern>
</servlet-mapping>

<servlet>
  <servlet-name>ReturnBookController</servlet-name>
  <servlet-class>br.com.atlas.webcontroller.ReturnBookController</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>ReturnBookController</servlet-name>
  <url-pattern>/returnBook</url-pattern>
</servlet-mapping>

</web-app>